# CSMAR MCP服务器配置
# 复制此文件为 .env 并填入真实的API信息

# ==================== HTTP API配置（旧版） ====================
# CSMAR API基础URL
CSMAR_API_BASE=https://api.gtarsc.com

# CSMAR API密钥（用于HTTP API）
CSMAR_API_KEY=your_csmar_api_key_here

# ==================== Python SDK配置（新版推荐） ====================
# CSMAR Python SDK登录凭据
# 获取方式：访问 us.gtadata.com 注册个人账号
CSMAR_USERNAME=your_csmar_username
CSMAR_PASSWORD=your_csmar_password
# 语言：0=中文，1=英文
CSMAR_LANG=0

# ==================== 服务器设置 ====================
PORT=3001
LOG_LEVEL=info

# ==================== 请求设置 ====================
TIMEOUT=30000
MAX_RETRIES=3
